<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.inventory.middle.infra.persistence.mapper.InventoryLogMapper">

    <resultMap id="BaseResultMap" type="com.inventory.middle.infra.persistence.entity.log.InventoryLogPO" >
        <result column="id" property="id" />
        <result column="tenant_id" property="tenantId" />
        <result column="request_id" property="requestId" />
        <result column="log_module" property="logModule" />
        <result column="action" property="action" />
        <result column="payload" property="payload" />
        <result column="report_time" property="reportTime" />
        <result column="creator_id" property="creatorId" />
        <result column="create_time" property="createTime" />
    </resultMap>

    <sql id="Base_Column_List">
        id,
        tenant_id,
        request_id,
        log_module,
        `action`,
        payload,
        report_time,
        creator_id,
        create_time
    </sql>

    <insert id="insert" useGeneratedKeys="true" keyColumn="id" keyProperty="id" parameterType="com.inventory.middle.infra.persistence.entity.log.InventoryLogPO">
        INSERT INTO inventory_log
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="null != tenantId and '' != tenantId">
                tenant_id,
            </if>
            <if test="null != requestId and '' != requestId">
                request_id,
            </if>
            <if test="null != logModule">
                log_module,
            </if>
            <if test="null != action">
                `action`,
            </if>
            <if test="null != payload and '' != payload">
                payload,
            </if>
            <if test="null != reportTime">
                report_time,
            </if>
            <if test="null != creatorId and '' != creatorId">
                creator_id,
            </if>
            <if test="null != createTime">
                create_time
            </if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="null != tenantId and '' != tenantId">
                #{tenantId},
            </if>
            <if test="null != requestId and '' != requestId">
                #{requestId},
            </if>
            <if test="null != logModule">
                #{logModule},
            </if>
            <if test="null != action">
                #{action},
            </if>
            <if test="null != payload and '' != payload">
                #{payload},
            </if>
            <if test="null != reportTime">
                #{reportTime},
            </if>
            <if test="null != creatorId and '' != creatorId">
                #{creatorId},
            </if>
            <if test="null != createTime">
                #{createTime}
            </if>
        </trim>
    </insert>

    <insert id="insertBatch" >
        insert into inventory_log (
            tenant_id,
            request_id,
            log_module,
            `action`,
            payload,
            report_time,
            creator_id,
            create_time
        )
        values
        <foreach collection="list" item="item" index="index" separator=",">
            (
            #{item.tenantId},
            #{item.requestId},
            #{item.logModule},
            #{item.action},
            #{item.payload},
            #{item.reportTime},
            #{item.creatorId},
            #{item.createTime}
            )
        </foreach>
    </insert>

    <select id="list" resultMap="BaseResultMap" parameterType="com.inventory.middle.infra.persistence.entity.log.InventoryLogQueryPO">
        select <include refid="Base_Column_List" />
        from inventory_log
        <where>
            <if test="null != id">
                and id = #{id}
            </if>
            <if test="null != tenantId and '' != tenantId">
                and tenant_id = #{tenantId}
            </if>
            <if test="null != requestId and '' != requestId">
                and request_id = #{requestId}
            </if>
            <if test="null != logModule">
                and log_module = #{logModule}
            </if>
            <if test="null != actionList and actionList.size() > 0">
                and `action` in
                <foreach collection="actionList" item="item" index="index" open="(" separator="," close=")">
                    #{item}
                </foreach>

            </if>
            <if test="null != operatorId and '' != operatorId">
                and creator_id = #{operatorId}
            </if>
            <if test="null != beginTime">
                and report_time &gt;= #{beginTime}
            </if>
            <if test="null != endTime">
                and report_time &lt;= #{endTime}
            </if>
        </where>
    </select>

</mapper>