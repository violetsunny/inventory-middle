    <select id="selectPlanByType" parameterType="com.enn.plan.management.dal.dao.condition.PlanQueryByTypeCondition"
            resultMap="ResultMapWithBLOBs">
        select
        <include refid="Base_Column_List"/>
        ,
        <include refid="Blob_Column_List"/>
        from `pl_plan`
        where deleted = 0
        and status = 1
        and plan_type = #{planType}
        <if test="null != tenantId">
            and tenant_id = #{tenantId}
        </if>
    </select>

    <select id="pageQueryPlan" parameterType="com.enn.plan.management.dal.dao.condition.PlanPageCondition"
            resultMap="ResultMapWithBLOBs">
        select
        <include refid="Base_Column_List"/>
        ,
        <include refid="Blob_Column_List"/>
        from `pl_plan`
        where tenant_id = #{tenantId}
        and deleted = 0
        <if test="null == status">
            and status in (0, 1)
        </if>
        <if test="null != status">
            and status = #{status}
        </if>
        and cover_material_type in (0, 1)
        <if test="null != planType">
            and plan_type = #{planType}
        </if>
        <if test="null != planCode and '' != planCode">
            and plan_code = #{planCode}
        </if>
        <if test="null != operatorName and '' != operatorName">
            and operator_name = #{operatorName}
        </if>
        <if test="null != planDesc and '' != planDesc">
            and plan_desc like concat('%', #{planDesc},'%')
        </if>
        order by update_time desc
    </select>
