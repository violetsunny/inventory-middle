    <select id="selectPlanCondition" parameterType="java.util.List" resultType="java.lang.String">
        select p.plan_code from pl_plan_material t INNER JOIN pl_plan p ON p.id=t.source_id where
        (t.tenant_id,t.source_id, t.logical_plant_no, t.material_code,t.deleted) IN
        <foreach item="item" index="index" collection="list" open="(" separator="," close=")">
