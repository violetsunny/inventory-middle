<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.inventory.middle.infra.plan.persistence.mapper.PlanInstanceMapper">

    <resultMap id="BaseResultMap" type="com.inventory.middle.infra.plan.persistence.entity.PlanInstancePO">
        <id column="id" jdbcType="BIGINT" property="id"/>
        <result column="plan_id" jdbcType="BIGINT" property="planId"/>
        <result column="plan_code" jdbcType="VARCHAR" property="planCode"/>
        <result column="plan_version" jdbcType="VARCHAR" property="planVersion"/>
        <result column="plan_type" jdbcType="INTEGER" property="planType"/>
        <result column="status" jdbcType="INTEGER" property="status"/>
        <result column="cal_start_time" jdbcType="TIMESTAMP" property="calStartTime"/>
        <result column="cal_end_time" jdbcType="TIMESTAMP" property="calEndTime"/>
        <result column="deleted" jdbcType="TINYINT" property="isDelete"/>
        <result column="create_time" jdbcType="TIMESTAMP" property="createTime"/>
        <result column="creator_id" jdbcType="VARCHAR" property="createUserId"/>
        <result column="tenant_id" jdbcType="VARCHAR" property="tenantId"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, plan_id, plan_code, plan_version, plan_type, status, cal_start_time, cal_end_time, deleted, create_time, creator_id, tenant_id
    </sql>

    <select id="selectById" parameterType="java.lang.Long" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from `pl_plan_instance`
        where id = #{id}
        and deleted = '0'
    </select>

    <select id="selectLatestByPlanId" parameterType="java.lang.Long" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from `pl_plan_instance`
        where plan_id = #{planid}
        and deleted = '0'
        order by cal_start_time desc
        limit 1
    </select>

    <insert id="insert" parameterType="com.inventory.middle.infra.plan.persistence.entity.PlanInstancePO"
            useGeneratedKeys="true" keyProperty="id">
        insert into `pl_plan_instance` (id, plan_id, plan_code, plan_version, plan_type, status,
                                             cal_start_time,cal_end_time,
                                             deleted, create_time, creator_id,
                                             tenant_id)
        values (#{id}, #{planId}, #{planCode}, #{planVersion},
                #{planType}, #{status},
                #{calStartTime},#{calEndTime},
                0, NOW(), #{createUserId},
                #{tenantId})
    </insert>


    <update id="update" parameterType="com.inventory.middle.infra.plan.persistence.entity.PlanInstancePO">
        update `pl_plan_instance`
        <set>
            <if test="planId != null">
                plan_id = #{planId},
            </if>
            <if test="planCode != null">
                plan_code = #{planCode},
            </if>
            <if test="planVersion != null">
                plan_version = #{planVersion},
            </if>
            <if test="planType != null">
                plan_type = #{planType},
            </if>
            <if test="status != null">
                status = #{status},
            </if>
            <if test="calStartTime != null">
                cal_start_time = #{calStartTime},
            </if>
            <if test="calEndTime != null">
                cal_end_time = #{calEndTime},
            </if>
            <if test="isDelete != null">
                deleted = #{isDelete},
            </if>
            <if test="tenantId != null">
                tenant_id = #{tenantId},
            </if>
        </set>
        where id = #{id}
    </update>
</mapper>