        </set>
        WHERE id = #{id}
    </update>

    <update id="reverse" parameterType="com.inventory.middle.infra.persistence.entity.InventoryDemandPO">
        UPDATE inventory_demand
        set unrestricted = unrestricted - #{unrestricted}

        WHERE material_doc_id = #{materialDocId}
          and batch_no = #{batchNo}
          and material_code = #{materialCode}
          and unrestricted - #{unrestricted} >= 0
    </update>


    <select id="load" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM inventory_demand
        WHERE id = #{id}
    </select>

    <select id="find" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM inventory_demand
        WHERE 1=1
        <if test="null != materialDocId ">and material_doc_id = #{materialDocId}</if>
        and batch_no = #{batchNo}
        and material_code = #{materialCode}
        and tenant_id = #{tenantId}
        <if test="null != locationId ">and location_id = #{locationId}</if>
        <if test="null != logicalPlantId ">and logical_plant_id = #{logicalPlantId}</if>
        and demand_type = 1
    </select>

    <select id="queryInventoryDemandByDay" parameterType="com.inventory.middle.infra.persistence.entity.inventory.InventoryDemandByDayQueryPO"
    resultType="com.inventory.middle.infra.persistence.entity.inventory.InventoryDemandByDayRespPO">
        SELECT
        DATE_FORMAT(t.deadline_date,'%Y-%m-%d') as deadlineDate,
        sum(t.unrestricted) as unrestricted
        FROM inventory_demand t
        WHERE t.tenant_id = #{tenantId}
        <if test="null != materialCode and '' != materialCode">and t.material_code = #{materialCode}</if>
        <if test="null != logicalPlantId ">and t.logical_plant_id = #{logicalPlantId}</if>
        <if test="null != startTime ">and t.deadline_date &gt;= #{startTime}</if>
        <if test="null != endTime ">and t.deadline_date &lt;= #{endTime}</if>
        and t.demand_type = 2
        and t.unrestricted > 0
        and t.deleted = 0
        group by DATE_FORMAT(t.deadline_date,'%Y-%m-%d');
    </select>

    <select id="queryPlanOutboundInventory"
            parameterType="com.inventory.middle.infra.persistence.entity.inventory.PlanOutboundInventoryQueryPO" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM inventory_demand t
        WHERE t.tenant_id = #{tenantId}
        <if test="null != materialCode and '' != materialCode">
            and t.material_code = #{materialCode}
        </if>
        <if test="null != logicalPlantId ">
          and t.logical_plant_id = #{logicalPlantId}
        </if>
        <if test="null != startTime">
            and t.pot  <![CDATA[ >= ]]> #{startTime}
        </if>
        <if test="null != endTime">
            and t.pot  <![CDATA[ <= ]]> #{endTime}
        </if>
        and t.demand_type = 2
        and t.deleted = 0
        and t.unrestricted > 0
    </select>

