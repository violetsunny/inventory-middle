    <update id="update" parameterType="com.inventory.middle.infra.persistence.entity.InventoryDemandPO">
        UPDATE inventory_demand
        <set>
            <if test="null != materialDocId ">material_doc_id = #{materialDocId},</if>
            <if test="null != materialCode and '' != materialCode">material_code = #{materialCode},</if>
            <if test="null != batchNo and '' != batchNo">batch_no = #{batchNo},</if>
            <if test="null != ownerId ">owner_id = #{ownerId},</if>
            <if test="null != logicalPlantId ">logical_plant_id = #{logicalPlantId},</if>
            <if test="null != locationId ">location_id = #{locationId},</if>
